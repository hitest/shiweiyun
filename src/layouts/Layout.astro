---
import '../styles/index.css';

export interface Props {
  title: string;
  lang: 'en' | 'zh';
  description?: string;
  lastUpdated?: string;
}

const { title, lang, description, lastUpdated } = Astro.props;

// For relative base paths, ensure site is configured in astro.config.mjs if deploying.
// For now, we use a placeholder or local site url to satisfy Astro.url based hreflang generation.
const siteUrl = Astro.site || new URL('https://hitest.github.io/shiweiyun/');
const currentPath = Astro.url.pathname;
const currentUrlStr = Astro.url.href;

let basePath = currentPath;
if (basePath.startsWith('/zh')) {
  basePath = basePath.replace(/^\/zh/, '');
}
if (basePath === '') basePath = '/';

const getUrlForLang = (targetLang: string) => {
  const origin = siteUrl.origin;
  const base = '/shiweiyun'; // Assuming GitHub Pages base
  let path = targetLang === 'en' ? basePath : `/${targetLang}${basePath}`;
  // Clean up double slashes
  path = path.replace(/\/\/+/g, '/');
  // Return URL matching exact mappings
  return new URL(base + path, origin).href.replace(/(?<=.)\/$/, '');
};

const enUrl = getUrlForLang('en');
const zhUrl = getUrlForLang('zh');

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Physician",
  "name": lang === 'en' ? "Prof. Shi Weiyun" : "史伟云 教授",
  "url": currentUrlStr,
  "description": description || "Official Medical Profile of Prof. Shi Weiyun.",
  "medicalSpecialty": [
    "Ophthalmology"
  ]
};
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    
    <!-- YMYL SEO: hreflang tags -->
    <link rel="canonical" href={currentUrlStr} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="zh" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-gray-50 text-gray-900">
    <slot />
    
    <!-- YMYL SEO: Footer Disclaimer & Transparency info added dynamically -->
    <footer class="bg-gray-100 py-6 mt-16 text-xs text-center border-t border-gray-200">
      <div class="max-w-7xl mx-auto px-6">
        <p><strong>Medical Disclaimer:</strong> The content provided on this website is for informational purposes only and is not a substitute for professional medical advice, diagnosis, or treatment.</p>
        <p class="mt-2">执业执照编号 (License/Reg No): 123456789 | 地址 (Address): 4 Jingshi Road, Jinan, Shandong, CN | <a href="/privacy" class="underline">隐私政策 (Privacy Policy)</a></p>
        {lastUpdated && <p class="mt-2 text-gray-500">Last Updated (内容最新由医生更新于): {lastUpdated}</p>}
      </div>
    </footer>
  </body>
</html>
